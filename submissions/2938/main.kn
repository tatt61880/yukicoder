func main()
	var n: int :: cui@inputInt()
	if(n > 100)
		ret
	end if
	
	var a: []int :: #[n]int
	for i(0, n - 1)
		do a[i] :: cui@inputInt()
	end for
	
	var ans: int :: 0
	for i(0, n - 1)
		for j(0, n - 1)
			do ans :+ (i - j).abs() * (a[i] - a[j]).abs()
		end for
	end for
	do cui@print("\{ans}\n")
end func
