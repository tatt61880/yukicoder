func main()
	var n: int :: cui@inputInt()
	var w: int :: cui@inputInt()
	var h: int :: cui@inputInt()
	var s: []char :: cui@inputStr()
	
	var ans: [][]char :: #[h, w]char
	for i(0, h - 1)
		for j(0, w - 1)
			do ans[i][j] :: 'x'
		end for
	end for
	
	var x: int :: 0
	var y: int :: h - 1
	for i(0, n - 1)
		if(s[i] = 'o')
			do ans[y][x] :: 'o'
			do y :- 1
		else
			do x :+ 1
			do y :: h - 1
		end if
	end for
	
	do cui@print(ans.join("\n") ~ "\n")
end func
