func main()
	var t: int :: cui@inputInt()
	for(1, t)
		var n: int :: cui@inputInt()
		var k: int :: cui@inputInt()
		var a: []int :: #[n]int
		for i(0, n - 1)
			do a[i] :: cui@inputInt()
		end for
		do a.sort()
		do a[0] :- k
		
		var ans: int :: 1
		for i(0, n - 1)
			do ans :* a[i]
		end for
		do cui@print("\{ans}\n")
	end for
end func
